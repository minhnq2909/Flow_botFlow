{
  "schemaVersion": "1.0",
  "workflow": {
    "schemaVersion": "1.0",
    "id": "web-search",
    "name": "Web Search",
    "version": 1,
    "nodes": [
      {
        "id": "begin-1",
        "type": "begin",
        "label": "Begin",
        "config": {
          "type": "begin",
          "data": { "variables": [{ "name": "query", "dataType": "string", "required": true }] }
        }
      },
      {
        "id": "web-search-1",
        "type": "web_search",
        "label": "Web Search",
        "config": {
          "type": "web_search",
          "data": {
            "provider": "openai",
            "modelId": "gpt-4.1-mini",
            "queryTemplate": "{{query}}",
            "maxSources": 8,
            "allowedDomains": []
          }
        }
      },
      {
        "id": "llm-1",
        "type": "llm",
        "label": "LLM",
        "config": {
          "type": "llm",
          "data": {
            "provider": "openai",
            "modelId": "gpt-4.1-mini",
            "systemPrompt": "Use the web context and preserve source attribution. Do not invent sources.",
            "userPromptTemplate": "Question:\n{{query}}\n\nWeb context:\n{{web-search-1.context}}",
            "temperature": 0.2,
            "maxOutputTokens": 700
          }
        }
      },
      {
        "id": "answer-1",
        "type": "answer",
        "label": "Answer",
        "config": { "type": "answer", "data": { "template": "{{llm-1.text}}" } }
      },
      {
        "id": "end-1",
        "type": "end",
        "label": "End",
        "config": { "type": "end", "data": { "outputVariable": "answer-1.text" } }
      }
    ],
    "edges": [
      { "id": "edge-1", "source": "begin-1", "target": "web-search-1" },
      { "id": "edge-2", "source": "web-search-1", "target": "llm-1" },
      { "id": "edge-3", "source": "llm-1", "target": "answer-1" },
      { "id": "edge-4", "source": "answer-1", "target": "end-1" }
    ]
  }
}
